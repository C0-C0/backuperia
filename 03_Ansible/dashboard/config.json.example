{
  "//": "Native Semaphore config (no Docker). Copy to /etc/semaphore/config.json.",
  "//db": "Embedded SQLite — a single file, no separate database server.",
  "sqlite": {
    "host": "/var/lib/semaphore/database.sqlite"
  },
  "dialect": "sqlite",

  "tmp_path": "/var/lib/semaphore/tmp",

  "//secrets": "Generate each with: head -c32 /dev/urandom | base64",
  "cookie_hash": "CHANGE_ME_base64_32_bytes",
  "cookie_encryption": "CHANGE_ME_base64_32_bytes",
  "access_key_encryption": "CHANGE_ME_base64_32_bytes",

  "//web": "web_host must match how you browse to it; used for links in the UI.",
  "web_host": "http://localhost:3000",
  "port": ":3000",

  "//schedule": "Timezone for cron schedules; without it Semaphore warns and uses UTC.",
  "schedule": {
    "timezone": "Europe/Zurich"
  },

  "email_alert": false
}
