# Copy to .env (same folder), fill in, keep OUT of git.

# --- Semaphore admin account (created on first start) ---
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@example.com
SEMAPHORE_ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- Postgres ---
SEMAPHORE_DB_PASS=CHANGE_ME_db_password

# --- Secret used to encrypt stored access keys. REQUIRED. ---
# Generate: openssl rand -base64 32
SEMAPHORE_ACCESS_KEY_ENCRYPTION=CHANGE_ME_base64_32_bytes
